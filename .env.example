# Fantasy Football Analysis - Environment Configuration
# Copy this file to .env and customize as needed

# API server
API_HOST=0.0.0.0
API_PORT=8000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Enable credentialed CORS requests (requires explicit non-wildcard CORS_ORIGINS)
CORS_ALLOW_CREDENTIALS=false

# Database path
DB_PATH=backend/database/data/nfl_cache.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG
# Console log level (DEBUG, INFO, WARNING, ERROR)
LOG_CONSOLE_LEVEL=INFO
# Log output root directory (contains errors/, timing/)
LOG_DIR=logs
# Number of per-run error log files to keep (<=0 keeps all)
ERROR_RUN_LOGS_KEEP=10

# Enable/disable timing instrumentation logs
TIMING_ENABLED=true
# Number of per-run timing log files to keep (<=0 keeps all)
TIMING_RUN_LOGS_KEEP=10
